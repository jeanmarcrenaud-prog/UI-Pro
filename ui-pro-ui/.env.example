# UI-Pro Frontend Environment Variables
#
# Copy this file to .env.local and customize values
# DO NOT commit .env.local - it's gitignored

# ========================
# API Configuration
# ========================

# FastAPI backend URL (port should match your backend config)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (for real-time chat)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ========================
# LLM Backend Configuration
# ========================

# Ollama (default LLM backend)
NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434

# LM Studio
NEXT_PUBLIC_LMSTUDIO_URL=http://localhost:1234

# llama.cpp
NEXT_PUBLIC_LLAMACPP_URL=http://localhost:8080

# Lemonade
NEXT_PUBLIC_LEMONADE_URL=http://localhost:13305

# Default model (used when API not available)
NEXT_PUBLIC_DEFAULT_MODEL=qwen3.5:9b