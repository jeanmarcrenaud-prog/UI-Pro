# Environment Configuration

# HF_TOKEN: Hugging Face API token (get at https://huggingface.co/settings/tokens)
# ⚠️ NEVER commit this file with a real token!
HF_TOKEN=your_huggingface_token_here

# OLLAMA_URL: URL to local Ollama server
OLLAMA_URL=http://localhost:11434

# MODEL_FAST: Fast coding model for Qwen-Coder tasks
MODEL_FAST=qwen2.5-coder:32b

# MODEL_REASONING: Reasoning model for planning/architecture
MODEL_REASONING=qwen-opus

# LLM_TIMEOUT: Timeout in seconds for LLM API calls
LLM_TIMEOUT=30

# EXECUTOR_TIMEOUT: Timeout for running generated apps in seconds
EXECUTOR_TIMEOUT=60

# WORKSPACE: Path to workspace directory (default: ./workspace)
# WORKSPACE=./workspace

# LOG_LEVEL: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# RATE_LIMIT_ENABLED: Enable API rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# RATE_LIMIT_REQUESTS_PER_MINUTE: Max requests per minute per client
# RATE_LIMIT_REQUESTS_PER_MINUTE=60

# RATE_LIMIT_REQUESTS_PER_HOUR: Max requests per hour per client
# RATE_LIMIT_REQUESTS_PER_HOUR=1000

# RATE_LIMIT_BURST_SIZE: Max burst of requests before rate limiting kicks in
# RATE_LIMIT_BURST_SIZE=10

# MEMORY_PERSIST_PATH: Path to FAISS vector index persistence file
# MEMORY_PERSIST_PATH=data/memory.index

# MEMORY_DOCS_PATH: Path to serialized memory documents
# MEMORY_DOCS_PATH=data/memory_docs.pkl

# CORS_ORIGINS: JSON array of allowed origins (default: localhost dev)
# CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://myapp.com"]

# CHECKPOINT_MAX_PER_THREAD: Max checkpoints kept per conversation thread
# CHECKPOINT_MAX_PER_THREAD=50

# MAX_MESSAGE_HISTORY: Max messages kept in conversation history
# MAX_MESSAGE_HISTORY=50
